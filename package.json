{
  "name": "goose-manager",
  "version": "3.1.2",
  "private": false,
  "license": "MIT",
  "type": "module",
  "repository": "https://github.com/redgoose-dev/goose-manager.git",
  "author": "redgoose <scripter@me.com>",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"bun run --bun server/main.js\" \"bunx --bun vite\"",
    "prebuild": "rm -rf ./dist",
    "build": "bun run --bun ./server/build.js && bunx --bun vite build",
    "build:client": "rm -rf ./dist && bunx --bun vite build",
    "build:server": "rm -rf ./dist && bun run --bun ./server/build.js",
    "preview": "NODE_ENV=production bun run --bun dist/main.js"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "dependencies": {
    "@types/bun": "^1.3.11"
  },
  "devDependencies": {
    "@redgoose/json-editor": "^1.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "image-resize": "^1.4.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^17.0.5",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "terser": "^5.46.1",
    "vite": "^8.0.3",
    "vue": "^3.5.31",
    "vue-advanced-cropper": "^2.8.9",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.0.4"
  }
}
